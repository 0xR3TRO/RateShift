# ==================================
# RateShift Environment Configuration
# ==================================
# Copy this file to .env and fill in your values.

# ---------- General ----------
NODE_ENV=development
PORT=5000

# ---------- External Exchange Rate API ----------
# Supported providers: exchangerate-api, openexchangerates, mock
EXCHANGE_PROVIDER=mock

# For exchangerate-api.com (free tier available)
EXCHANGE_API_KEY=your_api_key_here
EXCHANGE_API_BASE_URL=https://v6.exchangerate-api.com/v6

# For openexchangerates.org
# EXCHANGE_API_KEY=your_oer_api_key_here
# EXCHANGE_API_BASE_URL=https://openexchangerates.org/api

# ---------- Cache ----------
CACHE_TTL_MINUTES=5

# ---------- Rate Limiting ----------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- Client ----------
REACT_APP_API_BASE_URL=http://localhost:5000/api

# ---------- CORS ----------
CORS_ORIGIN=http://localhost:3000
